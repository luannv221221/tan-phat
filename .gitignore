# Credential — TUYET DOI khong commit
.env

# Session that cua nguoi dung.
# CHO MOI (tu Phase 0 H3) — session luu o day, ngoai public/
storage/sessions/*
!storage/sessions/.gitkeep

# CHO CU — giu lai de repo cu khong commit lai 16 file session da tung bi lo
public/logs/session/*
!public/logs/session/.gitkeep

# Log
public/logs/errors/*
!public/logs/errors/.gitkeep
public/logs/access/*
!public/logs/access/.gitkeep

# Backup truoc khi va Phase 0
_backup_truoc_phase0/

# He dieu hanh / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Composer
/vendor/

# Uploads — file nguoi dung tai len (logo hang, anh phu tung). Giu thu muc, bo qua noi dung.
public/assets/uploads/brands/*
!public/assets/uploads/brands/.gitkeep
public/assets/uploads/parts/*
!public/assets/uploads/parts/.gitkeep
public/assets/uploads/news/*
!public/assets/uploads/news/.gitkeep
public/assets/uploads/projects/*
!public/assets/uploads/projects/.gitkeep
