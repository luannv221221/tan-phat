# ============================================================
#  VirtualHost cho Tan Phat ERP tren XAMPP/Apache (Windows Server)
#
#  Dan noi dung nay vao:  C:\xampp\apache\conf\extra\httpd-vhosts.conf
#  Sua duong dan + ServerName cho dung, roi restart Apache.
#  (httpd-vhosts.conf da duoc include san trong httpd.conf cua XAMPP.)
# ============================================================

# ---- HTTP (cong 80) ----
<VirtualHost *:80>
    ServerName etek.rikkeiedu.org
    # Tro thang vao thu muc du an (KHONG phai htdocs)
    DocumentRoot "C:/xampp/htdocs/tan-phat"

    <Directory "C:/xampp/htdocs/tan-phat">
        # BAT BUOC: cho phep .htaccess cua du an hoat dong (rewrite + chan .env)
        AllowOverride All
        Require all granted
        Options -Indexes +FollowSymLinks
    </Directory>

    ErrorLog  "logs/tanphat-error.log"
    CustomLog "logs/tanphat-access.log" common
</VirtualHost>

# ---- HTTPS (cong 443) — bo comment khi da co chung chi SSL ----
# <VirtualHost *:443>
#     ServerName etek.rikkeiedu.org
#     DocumentRoot "C:/xampp/htdocs/tan-phat"
#
#     SSLEngine on
#     SSLCertificateFile      "conf/ssl.crt/tanphat.crt"
#     SSLCertificateKeyFile   "conf/ssl.key/tanphat.key"
#
#     <Directory "C:/xampp/htdocs/tan-phat">
#         AllowOverride All
#         Require all granted
#         Options -Indexes +FollowSymLinks
#     </Directory>
#
#     ErrorLog  "logs/tanphat-ssl-error.log"
#     CustomLog "logs/tanphat-ssl-access.log" common
# </VirtualHost>
