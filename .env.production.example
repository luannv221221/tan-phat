# ============================================================
#  .env cho MOI TRUONG PRODUCTION (Windows Server + XAMPP/Apache)
#  Copy file nay thanh `.env` tren server roi dien gia tri that.
#  KHONG commit .env vao git.
# ============================================================

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tanphat_php
# KHUYEN NGHI: tao user rieng (KHONG dung root) — xem DEPLOY_WINDOWS.md
DB_USER=tanphat_app
DB_PASS=DAT_MAT_KHAU_MANH_O_DAY

# --- Ung dung ---
# BAT BUOC = false o production (khong lo SQL/loi ra trinh duyet)
APP_DEBUG=false

# Neu chay bang VirtualHost tro thang vao thu muc du an (khuyen nghi): de "/"
# Neu dat trong htdocs\tanphat (chay qua http://host/tanphat): dat "/tanphat/"
APP_BASE_PATH=/

# URL day du that su cua site (dung domain that; co HTTPS thi ghi https)
APP_URL=https://erp.tanphat.vn

# --- Session ---
SESSION_COOKIE=tanphat_session
SESSION_LIFETIME=86400
# Neu doi thu muc luu session ra ngoai docroot (khuyen nghi cho production):
# SESSION_PATH=C:/ProgramData/tanphat/sessions
# BAT true khi site chay HTTPS (cookie chi gui qua SSL)
SESSION_SECURE=true
