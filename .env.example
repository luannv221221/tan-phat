# Copy file nay thanh .env roi dien thong tin that.
# .env KHONG duoc commit vao git (da co trong .gitignore).

# --- Database ---
DB_HOST=127.0.0.1
# DB_PORT: ban cu ep cung 3306. Can khai bao khi may chay nhieu instance MySQL.
DB_PORT=3306
DB_NAME=tanphat_php
DB_USER=root
DB_PASS=

# --- Ung dung ---
# APP_DEBUG=true  -> in chi tiet loi SQL ra man hinh (CHI dung khi dev)
# APP_DEBUG=false -> chi ghi log, tra ve thong bao chung (BAT BUOC o production)
APP_DEBUG=true

# Duong dan goc cua ung dung tren web server.
# Vi du chay o http://localhost/framework_11_12_2021_fix/ thi dat:
#   APP_BASE_PATH=/framework_11_12_2021_fix/
APP_BASE_PATH=/framework_11_12_2021_fix/

# Neu muon ep cung URL day du thi bo comment dong duoi:
# APP_URL=http://localhost/framework_11_12_2021_fix/

# --- Session ---
SESSION_COOKIE=tanphat_fw_session
SESSION_LIFETIME=86400

# Noi luu file session. BAT BUOC nam NGOAI thu muc web.
# Mac dinh la storage/sessions (da co .htaccess chan).
# O production nen tro han ra ngoai docroot, vi du:
#   SESSION_PATH=/var/lib/php/sessions/tanphat
# SESSION_PATH=

# SESSION_SECURE=true -> cookie chi gui qua HTTPS. BAT o production co SSL.
SESSION_SECURE=false
